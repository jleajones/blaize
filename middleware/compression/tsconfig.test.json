{
  "extends": "@blaizejs/tsconfig/test.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "exactOptionalPropertyTypes": false,
    "baseUrl": ".",
    "paths": {
      "@blaize-types/*": ["../../packages/blaize-types/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/blaize-types/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "examples"]
}

